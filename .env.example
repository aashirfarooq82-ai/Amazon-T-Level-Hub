# Environment variables
# Copy this file to .env and fill in with your configuration

NODE_ENV=development
PORT=3000

# CORS configuration - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,file://

# Database
DATABASE_PATH=./db/tlevels.db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email configuration (Gmail SMTP)
# Get your Gmail App Password from: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password-with-spaces
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=your-email@gmail.com
