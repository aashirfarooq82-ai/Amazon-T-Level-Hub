# Environment variables
# Copy this file to .env and fill in with your configuration

NODE_ENV=development
PORT=3000

# CORS configuration - comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,file://

# Database
DATABASE_PATH=./db/tlevels.db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email configuration (optional, for future notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Gemini API key for the chatbot (get one from https://aistudio.google.com/app/apikey)

GEMINI_API_KEY=AQ.Ab8RN6JTGLaC9nhqPsR6zGPLA-UncMmmcOhmRFsY7-5ezXKuAg
